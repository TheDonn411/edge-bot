# edge-bot API keys — copy to .env and fill in values (never commit .env)
# All keys are read at startup via EDGE_BOT__APIS__* env vars.

# Finnhub (free tier: congressional trades, insider Form 4, news)
# Sign up at https://finnhub.io
EDGE_BOT__APIS__FINNHUB_KEY=your_finnhub_key_here

# Alpha Vantage (free tier: 25 requests/day for news sentiment)
# Sign up at https://www.alphavantage.co/support/#api-key
EDGE_BOT__APIS__ALPHA_VANTAGE_KEY=your_alpha_vantage_key_here

# Financial Modeling Prep (free tier: 250 calls/day for analyst estimates)
# Sign up at https://financialmodelingprep.com/developer
EDGE_BOT__APIS__FMP_KEY=your_fmp_key_here

# Demo dashboard market data refresh
FMP_API_KEY=your_fmp_key_here

# Optional overrides (uncomment to use)
# EDGE_BOT__RISK__MAX_DRAWDOWN_PCT=0.15
# EDGE_BOT__RISK__DAILY_LOSS_LIMIT_PCT=0.05
# EDGE_BOT__EXECUTION__BROKER=ibkr_stub
